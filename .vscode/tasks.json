{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install dependencies",
      "type": "shell",
      "command": "python3 -m venv .venv && source .venv/bin/activate && python -m pip install --upgrade pip && pip install -r requirements.txt",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Run API server",
      "type": "shell",
      "command": "source .venv/bin/activate && uvicorn src.api:app --host 0.0.0.0 --port 8000",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Install dependencies",
      "problemMatcher": []
    }
  ]
}
